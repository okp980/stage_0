server {
    listen 80;
    listen [::]:80;

    # Replace with your domain or server IP
    server_name example.com www.example.com;

    # If you have a big payload (e.g., file uploads), bump this:
    client_max_body_size 25m;

    # Forward real client IP & proto to FastAPI (use --proxy-headers in Uvicorn)
    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;

        # WebSocket support (needed for FastAPI websockets and Uvicorn)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Standard proxy headers
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeouts (tune as needed for long requests/streams)
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;

        # Buffers (helps with large responses)
        proxy_buffering on;
        proxy_buffers 16 16k;
        proxy_busy_buffers_size 32k;
    }

    # (Optional) serve static files directly via Nginx
    # location /static/ {
    #     alias /path/to/static/;
    #     add_header Cache-Control "public, max-age=31536000, immutable";
    # }
}

# Map for robust websocket Upgrade header (recommended)
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
